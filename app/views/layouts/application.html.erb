<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>nemu the sleepy tamagotchi :3</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💤</text></svg>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:ital,opsz,wght@0,9..40,300..600;1,9..40,300..600&display=swap" rel="stylesheet">

    <style>
      :root {
        --font-mono: 'Space Mono', 'Courier New', monospace;
        --font-body: 'DM Sans', 'Helvetica Neue', sans-serif;
        --text-xs:   clamp(0.68rem,  0.65rem + 0.15vw, 0.78rem);
        --text-sm:   clamp(0.8rem,   0.75rem + 0.25vw, 0.9rem);
        --text-base: clamp(0.9rem,   0.85rem + 0.25vw, 1rem);
        --text-lg:   clamp(1.1rem,   0.95rem + 0.75vw, 1.4rem);
        --text-xl:   clamp(1.4rem,   1.1rem  + 1.25vw, 2rem);
        --text-2xl:  clamp(2rem,     1.2rem  + 2.5vw,  3.2rem);
        --space-1: 0.25rem; --space-2: 0.5rem;  --space-3: 0.75rem;
        --space-4: 1rem;    --space-5: 1.25rem; --space-6: 1.5rem;
        --space-8: 2rem;    --space-10: 2.5rem; --space-12: 3rem;
        --space-16: 4rem;
        --transition: 150ms cubic-bezier(0.16, 1, 0.3, 1);
      }

      :root, [data-theme="dark"] {
        --bg:        #080809;
        --surface:   #0f0f11;
        --surface-2: #151517;
        --surface-3: #1c1c1f;
        --border:    rgba(255,255,255,0.07);
        --border-hi: rgba(255,255,255,0.14);
        --text:      #dddbd5;
        --text-muted:#7a7a77;
        --text-faint:#3f3f3d;
        --accent:        #b8a0e8;
        --accent-hover:  #cbb8f0;
        --accent-dim:    rgba(184,160,232,0.12);
        --accent-dimmer: rgba(184,160,232,0.06);
        --stat-green:  #5ec45f;
        --stat-yellow: #e8c040;
        --stat-orange: #e8844a;
        --stat-red:    #d94848;
        --stat-blue:   #52aee8;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.5);
        --shadow-md: 0 4px 16px rgba(0,0,0,0.6);
        --scan-line: rgba(255,255,255,0.012);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; scroll-behavior: smooth; }

      body {
        min-height: 100dvh;
        font-family: var(--font-mono);
        font-size: var(--text-base);
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
        background-image: repeating-linear-gradient(
          0deg, transparent, transparent 3px,
          var(--scan-line) 3px, var(--scan-line) 4px
        );
        background-attachment: fixed;
      }

      img, svg { display: block; max-width: 100%; }
      button { cursor: pointer; background: none; border: none; font: inherit; color: inherit; }
      a { color: inherit; text-decoration: none; }
      a, button { transition: color var(--transition), background var(--transition), border-color var(--transition); }
      :focus-visible { outline: 1px solid var(--accent); outline-offset: 2px; }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }

      .page {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: var(--space-6) var(--space-4);
      }
      .main { width: 100%, max-width: 600px; flex: 1; }
      .site-header {
        width: 100%; max-width: 600px;
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: var(--space-6);
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--border);
      }
      .header-brand { display: flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--text-muted); }
      .header-brand .ps { color: var(--accent); user-select: none; }
      .brand-name { color: var(--text); font-weight: 700; letter-spacing: 0.05em; }
      .brand-name:hover { color: var(--accent); }
      .header-clock { font-size: var(--text-xs); color: var(--text-faint); font-variant-numeric: tabular-nums; }
      .flash-wrap { width: 100%; max-width: 600px; margin-bottom: var(--space-4); }
      .flash {
        font-size: var(--text-xs); padding: var(--space-2) var(--space-3);
        border-left: 2px solid var(--accent);
        background: var(--accent-dimmer); color: var(--text-muted);
        display: flex; align-items: center; gap: var(--space-2);
      }
      .flash::before { content: "> "; color: var(--accent); }
      .flash--alert { border-color: var(--stat-red); background: rgba(217,72,72,0.07); }
      .flash--alert::before { color: var(--stat-red); }
      .panel { background: var(--surface); border: 1px solid var(--border); }
      .panel-header {
        font-size: var(--text-xs); color: var(--accent);
        padding: var(--space-2) var(--space-3);
        border-bottom: 1px solid var(--border);
        background: var(--surface-2);
        letter-spacing: 0.06em;
      }
      .panel-header::before { content: "> "; color: var(--text-faint); }
      .panel-body { padding: var(--space-4) var(--space-3); }

      .stats-list { display: flex; flex-direction: column; gap: var(--space-3); }
      .stat-row {}
      .stat-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
      .stat-label { font-size: var(--text-xs); color: var(--text-muted); letter-spacing: 0.04em; }
      .stat-value { font-size: var(--text-xs); color: var(--text); min-width: 3ch; text-align: right; font-variant-numeric: tabular-nums; }
      .stat-bar-track { height: 3px; background: var(--surface-3); overflow: hidden; }
      .stat-bar-fill { height: 100%; transition: width 0.4s ease, background 0.4s ease; min-width: 2px; }
      .btn {
        font-family: var(--font-body); font-size: var(--text-xs);
        padding: var(--space-2) var(--space-3);
        background: var(--surface-2); border: 1px solid var(--border);
        color: var(--text-muted); cursor: pointer; letter-spacing: 0.04em;
        transition: all var(--transition); white-space: nowrap;
      }
      .btn:hover:not(:disabled) { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }
      .btn:active:not(:disabled) { transform: translateY(1px); }
      .btn:disabled { opacity: 0.22; cursor: not-allowed; }
      .btn--primary { background: var(--accent-dim); border-color: var(--accent); color: var(--accent); }
      .btn--primary:hover:not(:disabled) { background: var(--accent); color: var(--bg); }

      /* Actions grid */
      .actions-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); padding: var(--space-3); }
      .actions-sep { width: 1px; background: var(--border); align-self: stretch; margin: 0 2px; }
      .msg-log {
        font-size: var(--text-xs); color: var(--text-faint);
        padding: var(--space-2) var(--space-3);
        min-height: 2.2rem;
        display: flex; align-items: center; gap: var(--space-2);
        border-top: 1px solid var(--border);
        background: var(--surface-2);
      }
      .msg-log .ps { color: var(--text-faint); user-select: none; flex-shrink: 0; }
      .msg-ok  .msg-text { color: var(--stat-green); }
      .msg-err .msg-text { color: var(--stat-red); }
      .msg-log .msg-text { color: var(--text-muted); transition: color 0.2s; }

      @keyframes blink { 0%,100%{opacity:0} 50%{opacity:1} }
      .cursor {
        display: inline-block; width: 0.5em; height: 0.9em;
        background: var(--accent); opacity: 0;
        vertical-align: text-bottom; margin-left: 1px;
        animation: blink 1.1s step-end infinite;
      }

      .pet-display {
        display: flex; align-items: center; gap: var(--space-5);
        padding: var(--space5) var(--space4);
        background: var(--surface); border: 1px solid var(--border);
        margin-bottom: var(--space-4)
      }
      .pet-sprite-box {
        flex-shrink: 0; width: 68px; height: 68px;
        display: flex; align-items: center; justify-content: center;
        font-size: 3rem; line-height: 1;
        border: 1px solid var(--border); background: var(--surface-2);
        transition: opacity 0.3s;
      }
      .pet-sprite-box.sleeping { opacity: 0.6; }
      .pet-info { flex: 1; display: flex; flex-direction: column; gap: 3px; }
      .pet-name-row { display: flex; align-items: baseline; gap: var(--space-2); flex-wrap: wrap; }
      .pet-name { font-size: var(--text-lg); font-weight: 700; color: var(--text); }
      .pet-stage { font-size: var(--text-xs); color: var(--accent); letter-spacing: 0.05em; }
      .pet-meta { font-size: var(--text-xs); color: var(--text-faint); display: flex; flex-wrap: wrap; gap: var(--space-3); }
      .pet-meta .v { color: var(--text-muted); }
      .pet-flags { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-1); }
      .flag {
        font-size: 0.60rem; padding: 1px var(--space-2);
        border: 1px solid var(--border); color: var(--text-faint); background: var(--surface-3);
        letter-spacing: 0.06em;
      }
      .flag--sleep { border-color: var(--stat-blue);   color: var(--stat-blue);   background: rgba(82,174,232,0.08); }
      .flag--sick  { border-color: var(--stat-red);    color: var(--stat-red);    background: rgba(217,72,72,0.08);  }
      .flag--poop  { border-color: var(--stat-yellow); color: var(--stat-yellow); background: rgba(232,192,64,0.08); }

      .boot-screen { padding: var(--space-8) 0; font-size: var(--text-xs); }
      .boot-art { color: var(--accent); font-size: var(--text-xs); line-height: 1.5; margin-bottom: var(--space-6); white-space: pre; }
      .boot-lines { color: var(--text-faint); line-height: 2.2; margin-bottom: var(--space-8); }
      .boot-lines .hl { color: var(--text-muted); }
      .boot-lines .ok { color: var(--stat-green); }
      .boot-action {
        display: inline-flex; align-items: center; gap: var(--space-2);
        font-size: var(--text-sm); padding: var(--space-2) var(--space-5);
        background: var(--accent-dim); border: 1px solid var(--accent);
        color: var(--accent); letter-spacing: 0.04em; transition: all var(--transition);
      }
      .boot-action:hover { background: var(--accent); color: var(--bg); }

      /* npi */
      .init-screen { padding: var(--space-8) 0; }
      .init-header { font-size: var(--text-xs); color: var(--text-faint); margin-bottom: var(--space-6); line-height: 2.2; }
      .init-header .hl { color: var(--text-muted); }
      .form-line {
        display: flex; align-items: center; gap: var(--space-2);
        margin-bottom: var(--space-3);
        border: 1px solid var(--border); background: var(--surface);
        padding: var(--space-2) var(--space-3);
      }
      .form-line:focus-within { border-color: var(--accent); }
      .form-prompt { color: var(--accent); flex-shrink: 0; font-size: var(--text-sm); }
      .form-label  { color: var(--text-faint); flex-shrink: 0; font-size: var(--text-xs); min-width: 6ch; }
      .form-input {
        flex: 1; background: transparent; border: none;
        color: var(--text); font-family: var(--font-mono); font-size: var(--text-sm);
        outline: none; caret-color: var(--accent);
      }
      .form-input::placeholder { color: var(--text-faint); }
      .form-error { font-size: var(--text-xs); color: var(--stat-red); padding: var(--space-1) 0 var(--space-2); }
      .form-error::before { content: "! "; }
      .dead-screen { text-align: center; padding: var(--space-12) var(--space-4); color: var(--text-faint); }
      .dead-sprite { font-size: 3.5rem; margin-bottom: var(--space-6); }
      .dead-title  { font-size: var(--text-base); color: var(--text-muted); margin-bottom: var(--space-2); }
      .dead-cause  { font-size: var(--text-xs); color: var(--text-faint); margin-bottom: var(--space-8); }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="site-header">
        <div class="header-brand">
          <span class="ps">$</span>
          <a href="/" class="brand-name">nemu :3</a>
          <span style="color:var(--text-faint)"> - tamagotchi for the sleepy at heart!!</span>
        </div>
        <div class="header-clock" id="hclock"></div>
      </header>

      <% if notice.present? %>
        <div class="flash-wrap"><div class="flash"><%= notice %></div></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash-wrap"><div class="flash flash--alert"><%= alert %></div></div>
      <% end %>

      <main class="main">
        <%= yield %>
      </main>

    </div>
    <script>
      (function() {
        var el = document.getElementById('hclock');
        function t() { if(el) el.textContent = new Date().toLocaleTimeString('en-US',{hour12:false}); }
        t(); setInterval(t, 1000);
      })();
    </script>
  </body>
</html>