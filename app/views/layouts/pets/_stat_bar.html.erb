<%# locals: id, label, value, invert (optional), neutral (optional) %>
<div class="stat-row" id="<%= id %>">
    <div class="stat-header">
        <span class="stat-label"><%= label %></span>
        <span class="stat-value"><%= value %></span>
    </div>
    <div class="stat-bar-track">
        <div class="stat-bar-fill" style="width: <%= value %>%; background: var(--stat-green);"></div>
    </div>
</div>
